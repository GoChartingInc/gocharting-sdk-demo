{
	"name": "gocharting-sdk-demo-cra",
	"version": "0.1.0",
	"private": true,
	"repository": {
		"type": "git",
		"url": "https://github.com/GoChartingInc/gocharting-sdk-demo.git"
	},
	"scripts": {
		"start": "craco start",
		"build": "craco build",
		"test": "craco test",
		"eject": "react-scripts eject",
		"build:sdk": "cd $(node sdk.config.js) && pnpm run build:webpack",
		"build:start": "npm run build:sdk && pnpm install --force && pnpm start",
		"start:all": "concurrently -n demo,sdk -c blue,green \"pnpm start\" \"cd $(node sdk.config.js) && pnpm run build:watch:all:typed\""
	},
	"dependencies": {
		"@emotion/react": "^11.14.0",
		"@emotion/styled": "^11.14.1",
		"@gocharting/chart-sdk": "1.0.70",
		"framer-motion": "^12.23.24",
		"moment": "^2.30.1",
		"react": "^19.2.0",
		"react-app-polyfill": "^3.0.0",
		"react-dom": "^19.2.0",
		"react-router-dom": "^7.12.0",
		"web-vitals": "^5.1.0"
	},
	"devDependencies": {
		"@craco/craco": "^7.1.0",
		"@testing-library/dom": "^10.4.0",
		"@testing-library/jest-dom": "^6.6.3",
		"@testing-library/react": "^16.1.0",
		"@testing-library/user-event": "^14.6.1",
		"@types/jest": "^30.0.0",
		"@types/node": "^25.0.8",
		"@types/react": "^19.0.0",
		"@types/react-dom": "^19.0.0",
		"@types/react-router-dom": "^5.3.3",
		"concurrently": "^9.2.1",
		"react-scripts": "5.0.1",
		"sass": "^1.97.3",
		"typescript": "^5.2.2"
	},
	"eslintConfig": {
		"extends": [
			"react-app",
			"react-app/jest"
		]
	},
	"browserslist": {
		"production": [
			">0.2%",
			"not dead",
			"not op_mini all"
		],
		"development": [
			"last 1 chrome version",
			"last 1 firefox version",
			"last 1 safari version"
		]
	}
}
