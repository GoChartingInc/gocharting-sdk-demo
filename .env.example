# ─────────────────────────────────────────────────────────────────────────────
# Data provider configuration (Create React App reads only REACT_APP_* vars).
# Copy to `.env` and fill in. Restart `pnpm start` after changing.
# ─────────────────────────────────────────────────────────────────────────────

# Relay proxy for CORS/geo-blocked exchange REST hosts (okx, gateio, mexc,
# poloniex, bitfinex, cryptocom, bitstamp). Default is the public allorigins
# relay; for production point this at your own backend relay. Set to "" to
# disable proxying (direct fetch — those providers will then fail in-browser).
# REACT_APP_DATA_PROXY=https://api.allorigins.win/raw?url=

# ── Keyed multi-asset vendors (forex / stocks / crypto) ──────────────────────
# Free key: https://finnhub.io  — live trades over WS work on free tier;
#                                  candle history is gated (premium) → demo fallback.
REACT_APP_FINNHUB_API_KEY=

# Free key: https://polygon.io   — delayed/EOD aggregate history on free tier;
#                                  realtime WS requires a paid plan.
REACT_APP_POLYGON_API_KEY=

# Free key: https://www.alphavantage.co/support/#api-key
#                                  — daily bars only, 25 requests/day, no WS.
REACT_APP_ALPHAVANTAGE_API_KEY=

# Twelve Data (forex/stocks/crypto). The repo ships a demo key; use your own
# for real testing: https://twelvedata.com
REACT_APP_TWELVEDATA_API_KEY=
